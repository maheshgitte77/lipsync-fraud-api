# =============================================================================
# lipsync-fraud-api — environment variables (complete list)
# Copy to ".env" in the project root. Loaded on import via python-dotenv.

# =============================================================================
# lipsync-fraud-api — environment variables
# Copy to ".env" in the project root and adjust. Loaded automatically on import
# if python-dotenv is installed (see requirements.txt).
# =============================================================================

#
# Sections: (1) Paths & fusion (2) SyncNet scoring (3) SyncNet subprocess
#           (4) MediaPipe pipeline (5) Debug (6) Inherited — not app-specific
# =============================================================================

# =============================================================================
# 1) Paths & fusion
# =============================================================================

# SYNCNET_DIR — Path to cloned joonson/syncnet_python (run_pipeline.py, weights).
# Default: <project_root>/syncnet_python
# -----------------------------------------------------------------------------
# SYNCNET_DIR
# Absolute or relative path to the cloned joonson/syncnet_python repository.
# Must contain run_pipeline.py, run_syncnet.py, data/syncnet_v2.model, and
# detectors/s3fd/weights/sfd_face.pth after download_model.
# Default (if unset): <project_root>/syncnet_python
# -----------------------------------------------------------------------------
SYNCNET_DIR=./syncnet_python

# LIPSYNC_TEMP_DIR — Uploads + SyncNet work dirs (pyavi, pycrop, pyframes, …).
# Default: <project_root>/temp_videos
# -----------------------------------------------------------------------------
# LIPSYNC_TEMP_DIR
# Directory for per-job uploads and SyncNet intermediate files (pyavi, pycrop,
# etc.). Created automatically; should be writable and on a disk with enough
# space for decoded frames.
# Default (if unset): <project_root>/temp_videos
# -----------------------------------------------------------------------------
LIPSYNC_TEMP_DIR=./temp_videos

# LIPSYNC_FUSION — How SyncNet + MediaPipe merge into top-level verdict:
#   any | all | syncnet_only | mediapipe_only | best
# Default: any
# -----------------------------------------------------------------------------
# LIPSYNC_FUSION
# How to combine SyncNet and MediaPipe results into the top-level verdict.
#   any             — PASS if either method passes (default; most lenient).
#   all             — PASS only if both SyncNet and MediaPipe pass (strict).
#   syncnet_only    — Ignore MediaPipe for the final pass/fail.
#   mediapipe_only  — Ignore SyncNet for the final pass/fail.
#   best            — Same pass/fail rule as "any"; when BOTH fail, response
#                     includes fusion.closer_to_pass and margins for review.
# -----------------------------------------------------------------------------
LIPSYNC_FUSION=any

# =============================================================================
# 2) SyncNet — PASS/FAIL thresholds (applied in app after subprocess scores)
# =============================================================================

# MIN_DIST_PASS — SyncNet "Min dist" must be <= this to PASS (lower = stricter match).
# Default: 6.0
# -----------------------------------------------------------------------------
# MIN_DIST_PASS (SyncNet)
# Maximum allowed SyncNet "Min dist" for a PASS (lower distance = stronger
# lip–audio match in embedding space). Typical literature uses ~6; stricter
# values (e.g. 5) reduce false accepts; looser (e.g. 7–8) reduce false rejects
# on noisy phone video. Tune on your own labeled data.
# Default: 6.0
# -----------------------------------------------------------------------------
MIN_DIST_PASS=6.0

# CONFIDENCE_PASS — SyncNet "Confidence" must be >= this to PASS.
# Default: 3.0
# -----------------------------------------------------------------------------
# CONFIDENCE_PASS (SyncNet)
# Minimum allowed SyncNet "Confidence" for a PASS (model certainty on the
# sync estimate). Higher = require more decisive scores.
# Default: 3.0
# -----------------------------------------------------------------------------
CONFIDENCE_PASS=3.0

# =============================================================================
# 3) SyncNet — optional subprocess args (unset = upstream script defaults)
# Passed to run_pipeline.py / run_syncnet.py only when set.
# =============================================================================

# SYNCNET_FRAME_RATE — Force processing FPS (default upstream: 25).
# SYNCNET_FRAME_RATE=25

# SYNCNET_MIN_TRACK — Min frames per face track (default upstream: 100).
# SYNCNET_MIN_TRACK=100

# SYNCNET_FACEDET_SCALE — S3FD input scale (default upstream: 0.25).
# SYNCNET_FACEDET_SCALE=0.25

# SYNCNET_CROP_SCALE — Face crop padding (default upstream: 0.40).
# SYNCNET_CROP_SCALE=0.40

# SYNCNET_NUM_FAILED_DET — Missed detections before track break (default: 25).
# SYNCNET_NUM_FAILED_DET=25

# SYNCNET_MIN_FACE_SIZE — Min face size in pixels (default: 100).
# SYNCNET_MIN_FACE_SIZE=100

# SYNCNET_BATCH_SIZE — run_syncnet.py batch size (default upstream: 20).
# SYNCNET_BATCH_SIZE=20

# SYNCNET_VSHIFT — SyncNet temporal search half-window in frames (default: 15).
# SYNCNET_VSHIFT=15

# =============================================================================
# 4) MediaPipe + audio correlation pipeline
# =============================================================================

# -----------------------------------------------------------------------------
# MEDIAPIPE_CORR_THRESHOLD
# Minimum Pearson correlation between normalized lip openness (MediaPipe) and
# per-frame audio RMS for a MediaPipe PASS. Range about -1..1; 0.4 is a common
# starting point. Raise (e.g. 0.5) to be stricter; lower (e.g. 0.3) for hard
# lighting or low-resolution interviews.
# Default: 0.4
# -----------------------------------------------------------------------------
MEDIAPIPE_CORR_THRESHOLD=0.4

# MEDIAPIPE_CORR_BORDERLINE — Below PASS threshold but above this → "weak/borderline" reason text.
# Default: 0.25
MEDIAPIPE_CORR_BORDERLINE=0.25

# LIPSYNC_FFMPEG — ffmpeg executable name or full path (audio extract for MediaPipe).
# Default: ffmpeg (must be on PATH unless you set a full path).
LIPSYNC_FFMPEG=ffmpeg

# MEDIAPIPE_AUDIO_SAMPLE_RATE — Hz for extracted WAV and librosa (default 16000).
MEDIAPIPE_AUDIO_SAMPLE_RATE=16000

# MEDIAPIPE_FPS_FALLBACK — If video reports FPS 0/invalid, use this for frame↔audio alignment.
# Default: 25
MEDIAPIPE_FPS_FALLBACK=25

# MEDIAPIPE_MAX_NUM_FACES — Face Mesh max faces (default 1; use 1 for interviews).
MEDIAPIPE_MAX_NUM_FACES=1

# MEDIAPIPE_MIN_DETECTION_CONFIDENCE — Face Mesh initial detection threshold (0–1).
# Default: 0.5
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5

# MEDIAPIPE_MIN_TRACKING_CONFIDENCE — Face Mesh tracking threshold (0–1).
# Default: 0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

# MEDIAPIPE_MIN_FRAMES — Minimum frames required before computing correlation.
# Default: 5
MEDIAPIPE_MIN_FRAMES=5

# --- MediaPipe Tasks model (used when `import mediapipe` has no `.solutions`, e.g. 0.10.30+)
# MEDIAPIPE_FACE_MODEL_PATH — Path to face_landmarker.task (skip download if set).
# MEDIAPIPE_FACE_MODEL_PATH=C:/path/to/face_landmarker.task

# MEDIAPIPE_MODEL_CACHE — Directory where face_landmarker.task is stored after first download.
# Default: <project_root>/.cache
# MEDIAPIPE_MODEL_CACHE=./.cache

# MEDIAPIPE_FACE_MODEL_URL — Override download URL for face_landmarker.task (rare).
# Default: Google storage "latest" float16 face_landmarker task.

# =============================================================================
# 5) Debug
# =============================================================================

# LIPSYNC_DEBUG_LOG — Set to 1 to attach SyncNet log tail / all_tracks in JSON.
# LIPSYNC_DEBUG_LOG=1
# -----------------------------------------------------------------------------
# LIPSYNC_DEBUG_LOG
# Set to 1 to include extra debug fields in JSON: SyncNet raw log tail and
# per-track details when available. Increases response size; use for
# troubleshooting only.
# Default: unset (off)
# -----------------------------------------------------------------------------
# LIPSYNC_DEBUG_LOG=1

# =============================================================================
# 6) Inherited by SyncNet subprocess (same Python/torch), not read by app code
# Documented here so you know they affect GPU/CPU behavior.
# =============================================================================

# CUDA_VISIBLE_DEVICES — e.g. "0" or "" to force CPU in child if configured.
# OMP_NUM_THREADS — Cap BLAS/OpenMP threads.
# PYTHONUTF8=1 is set inside the app for the SyncNet subprocess.



# ============================================= env =============================================

# lipsync-fraud-api — see .env.example for every variable and comments
# lipsync-fraud-api — local overrides (see .env.example for full documentation)

SYNCNET_DIR=./syncnet_python
LIPSYNC_TEMP_DIR=./temp_videos
# LIPSYNC_FUSION=all
LIPSYNC_FFMPEG=ffmpeg
LIPSYNC_FUSION=syncnet_only
PROCTOR_LIPSYNC_FLAG_SOURCE=syncnet_only
LIPSYNC_DISABLE_MEDIAPIPE_LIPSYNC=true

# SyncNet: min_dist must be <= this to pass; confidence must be >= CONFIDENCE_PASS
MIN_DIST_PASS=12.0
CONFIDENCE_PASS=1.65

# MediaPipe: correlation (lip motion vs audio energy) must be >= this to pass
MEDIAPIPE_CORR_THRESHOLD=0.3
MEDIAPIPE_CORR_BORDERLINE=0.20
MEDIAPIPE_AUDIO_SAMPLE_RATE=16000
MEDIAPIPE_FPS_FALLBACK=30
MEDIAPIPE_MAX_NUM_FACES=1
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5
MEDIAPIPE_MIN_FRAMES=5

# Optional SyncNet subprocess tuning (uncomment to override upstream defaults):
# SYNCNET_FRAME_RATE=25
# SYNCNET_MIN_TRACK=100
# SYNCNET_BATCH_SIZE=20
# SYNCNET_VSHIFT=15

# Uncomment for verbose SyncNet output in API responses

# LIPSYNC_DEBUG_LOG=1



# Proctor Model Signals
ENABLE_PROCTOR_MODEL_SIGNALS=true
PROCTOR_MODEL_API_URL=http://localhost:8000
PROCTOR_MODEL_API_TIMEOUT_MS=180000


# Proctor Model Signals Thresholds
PROCTOR_SAMPLE_FPS=1.0
PROCTOR_OFFSCREEN_RATIO_THRESHOLD=0.25
PROCTOR_IMPROPER_HEAD_RATIO_THRESHOLD=0.25
PROCTOR_REPETITIVE_PATTERN_THRESHOLD=6

PROCTOR_MAX_FRAME_WIDTH=480
PROCTOR_SKIP_SYNCNET=false


EYE_SCAN_CYCLES_THRESHOLD=20


# HEAD_YAW_LEFT_THRESHOLD=-0.10
# HEAD_YAW_RIGHT_THRESHOLD=0.10
# HEAD_PITCH_UP_THRESHOLD=0.14
# HEAD_PITCH_DOWN_THRESHOLD=0.42

EYE_IRIS_JITTER_DELTA_MIN=0.030
EYE_IRIS_BLINK_LID_SPAN_MIN=0.012
PROCTOR_SAMPLE_FPS=1
PROCTOR_FPS_MIN=5
PROCTOR_FPS_MAX=120
PROCTOR_FPS_FALLBACK=30