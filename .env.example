# =============================================================================
# lipsync-fraud-api — environment variables
# Copy to ".env" in the project root. Loaded via python-dotenv on import.
# =============================================================================

# ---------------- App ----------------
LOG_LEVEL=INFO

# ---------------- Device (GPU/CPU) ----------------
# DEVICE: cpu | gpu | auto (default: auto)
#   auto → use CUDA if torch+cuda is available, else CPU.
#   gpu  → force GPU; falls back to CPU with a warning if CUDA missing.
#   cpu  → force CPU (also sets CUDA_VISIBLE_DEVICES= for subprocesses).
DEVICE=auto
GPU_ID=0
TORCH_ALLOW_TF32=true

# ---------------- Paths ----------------
SYNCNET_DIR=./syncnet_python
LIPSYNC_TEMP_DIR=./temp_videos
LIPSYNC_FFMPEG=ffmpeg
LIPSYNC_FFPROBE=ffprobe

# ---------------- SyncNet thresholds + windowing ----------------
MIN_DIST_PASS=12.0
CONFIDENCE_PASS=1.65
LIPSYNC_VIDEO_TRIM=true
LIPSYNC_TRIM_MAX_SECONDS=15
LIPSYNC_WINDOW_POSITION=middle
LIPSYNC_DOWNLOAD_TIMEOUT_SEC=600
LIPSYNC_DOWNLOAD_RETRIES=3
# LIPSYNC_DEBUG_LOG=1

# ---------------- SyncNet subprocess tuning ----------------
SYNCNET_FRAME_RATE=30
SYNCNET_MIN_TRACK=100
SYNCNET_BATCH_SIZE=20
SYNCNET_VSHIFT=15
# SYNCNET_FACEDET_SCALE=
# SYNCNET_CROP_SCALE=
# SYNCNET_NUM_FAILED_DET=
# SYNCNET_MIN_FACE_SIZE=

# ---------------- Proctor (eye + head) ----------------
PROCTOR_SAMPLE_FPS=1.0
PROCTOR_OFFSCREEN_RATIO_THRESHOLD=0.35
PROCTOR_IMPROPER_HEAD_RATIO_THRESHOLD=0.25
PROCTOR_REPETITIVE_PATTERN_THRESHOLD=5
PROCTOR_MAX_FRAME_WIDTH=480
PROCTOR_SKIP_SYNCNET=false
PROCTOR_LIPSYNC_FLAG_SOURCE=syncnet_only
PROCTOR_FPS_MIN=5
PROCTOR_FPS_MAX=120
PROCTOR_FPS_FALLBACK=30
HEAD_POSE_USE_TRANSFORM=true
HEAD_YAW_LEFT_THRESHOLD=-0.18
HEAD_YAW_RIGHT_THRESHOLD=0.18
HEAD_PITCH_UP_THRESHOLD=0.12
HEAD_PITCH_DOWN_THRESHOLD=0.50
HEAD_YAW_LEFT_DEG=-18
HEAD_YAW_RIGHT_DEG=18
HEAD_PITCH_UP_DEG=-12
HEAD_PITCH_DOWN_DEG=15
HEAD_POSE_HOLD_FRAMES=2
EYE_COUNT_ONLY_WHEN_FRONTAL=true
EYE_HORIZONTAL_CENTER_BAND=0.12
EYE_IRIS_JITTER_DELTA_MIN=0.030
EYE_IRIS_BLINK_LID_SPAN_MIN=0.012
EYE_VERTICAL_UP_BAND=0.16
EYE_VERTICAL_DOWN_BAND=0.12
EYE_VERTICAL_BASELINE_ALPHA=0.08
EYE_VERTICAL_BASELINE_CLAMP=0.12
EYE_ADAPTIVE_ENABLED=true
EYE_ADAPTIVE_MIN_SAMPLES=20
EYE_ADAPTIVE_K_HORIZONTAL=2.8
EYE_ADAPTIVE_K_UP=3.2
EYE_ADAPTIVE_K_DOWN=1.9
EYE_ADAPTIVE_BAND_MIN=0.08
EYE_ADAPTIVE_BAND_MAX=0.30
EYE_ADAPTIVE_STD_MIN=0.015
EYE_STEADY_DIRECTION_HOLD_FRAMES=3
PROCTOR_WARMUP_SEC=2.0
PROCTOR_COOLDOWN_SEC=2.0
EYE_SUSTAINED_GAZE_SEC=3.0
EYE_SCAN_CYCLES_THRESHOLD=20

# ---------------- Kafka (async proctor jobs) ----------------
PROCTOR_KAFKA_ENABLED=false
PROCTOR_KAFKA_BROKERS=localhost:9092
PROCTOR_KAFKA_REQUEST_TOPIC=proctor.signals.requests
PROCTOR_KAFKA_RESULT_TOPIC=proctor.signals.results
PROCTOR_KAFKA_GROUP=lipsync-fraud-proctor-workers
PROCTOR_KAFKA_START_WORKER=false

# ---------------- Redis (job state store) ----------------
# Either REDIS_URL alone, or REDIS_HOST+REDIS_PORT (+username/password) components.
# REDIS_URL=redis://default:password@host:6379
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
PROCTOR_JOB_STORE_PREFIX=proctor:job
PROCTOR_JOB_TTL_SEC=86400

# ---------------- TTS ----------------
# Supported providers: elevenlabs, cartesia, deepgram, inworld, xai, sarvam, google
# NEVER commit real API keys to this file. Use .env (gitignored) for secrets.
TTS_DEFAULT_PROVIDER=elevenlabs
TTS_FALLBACK_ORDER=elevenlabs,cartesia,deepgram,inworld,xai,sarvam,google
TTS_AUDIO_SAMPLE_RATE=24000

# ElevenLabs — voice_id can be a name (Rachel, Domi, Bella) or UUID from dashboard.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Rachel
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Google Cloud TTS — point at a service-account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_LANGUAGE=en-US

# Deepgram Aura — model family + voice are composed into the compound id
# (aura-2-athena-en). Pass voice_id=athena, model_id=aura-2, language=en.
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2
DEEPGRAM_TTS_VOICE=athena
DEEPGRAM_TTS_LANGUAGE=en

# Cartesia — voice_id is a UUID from the Cartesia dashboard.
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02
CARTESIA_MODEL=sonic-english

# Inworld — voice_id is the voice NAME (Arjun, Ashley, Saanvi, ...).
INWORLD_API_KEY=
INWORLD_VOICE_ID=Arjun
INWORLD_MODEL=inworld-tts-1.5-mini

# xAI (Grok TTS) — voice ids: ara, eve, rex, sal, leo.
XAI_API_KEY=
XAI_TTS_VOICE=ara
XAI_TTS_LANGUAGE=auto
XAI_TTS_MODEL=tts-1

# Sarvam AI — speaker + target_language_code are required.
SARVAM_API_KEY=
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE=en-IN

# ---------------- HeyGen (cloud avatar video generation) ----------------
# Separate, fully-customizable integration. Only used by /heygen/* endpoints.
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=
HEYGEN_DEFAULT_WIDTH=1280
HEYGEN_DEFAULT_HEIGHT=720
HEYGEN_REQUEST_TIMEOUT=60
HEYGEN_POLL_INTERVAL_SEC=5
HEYGEN_POLL_MAX_WAIT_SEC=900
# If true, download the final HeyGen MP4 and re-upload it to our S3/local storage.
HEYGEN_MIRROR_TO_STORAGE=false

# ---------------- Storage (final artifacts) ----------------
# backend: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./output
S3_BUCKET=
S3_PREFIX=avatars/
AWS_REGION=ap-south-1
S3_SIGNED_URL_TTL=3600
